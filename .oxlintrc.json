{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxlint-config-schema/main/oxlintrc.json",
  "plugins": ["typescript", "import", "react", "react-perf", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off"
  },
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-unused-vars": "warn"
  },
  "ignorePatterns": [
    "dist/**",
    "build/**",
    "node_modules/**",
    ".react-router/**",
    ".wrangler/**"
  ]
}
