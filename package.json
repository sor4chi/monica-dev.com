{
  "name": "website",
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "fix": "pnpm lint:fix && pnpm format",
    "dev:portfolio": "pnpm run --filter portfolio dev",
    "dev:dashboard": "pnpm run --filter @sor4chi/dashboard dev"
  },
  "devDependencies": {
    "oxlint": "^1.0.0",
    "oxfmt": "^0.1.0",
    "typescript": "^5.9.3"
  }
}
