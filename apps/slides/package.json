{
  "name": "slides",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx ./scripts/slidev-bulk.ts build",
    "dev": "slidev $(ls slides/*.md | fzf)",
    "export:pdf": "tsx ./scripts/export-pdfs.ts",
    "export:thumbnails": "tsx ./scripts/export-thumbnails.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fix": "pnpm lint:fix"
  },
  "dependencies": {
    "@slidev/cli": "52.14.2",
    "@slidev/theme-default": "0.25.0",
    "@slidev/theme-seriph": "0.25.0",
    "slidev-theme-eloc": "1.1.0",
    "vue": "3.5.32"
  },
  "devDependencies": {
    "fast-glob": "3.3.3",
    "playwright-chromium": "1.59.1",
    "tsx": "4.21.0"
  }
}
