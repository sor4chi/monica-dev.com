    "npm-run-all": "^4.1.5",
    "picocolors": "^1.1.1",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.32.6",
    "textlint": "^14.8.4",
    "textlint-rule-preset-ja-spacing": "^2.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^4.3.2"
