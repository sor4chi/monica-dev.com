{
  "name": "portfolio",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "npm run generate:ogp && react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fix:textlint": "textlint --fix ./src/**/*.md",
    "fix": "run-s lint:fix fix:textlint",
    "optimize": "tsx ./scripts/optimize",
    "generate:ogp": "tsx ./scripts/ogp",
    "prebuild": "npm run optimize"
  },
  "dependencies": {
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@sor4chi/design-system": "workspace:^",
    "@sor4chi/unified-plugins": "workspace:^",
    "clsx": "^2.1.1",
    "isbot": "^5.1.38",
    "katex": "^0.16.45",
    "mikanjs": "^1.0.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.14.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.1",
    "@shikijs/rehype": "^1.29.2",
    "@shikijs/transformers": "^1.29.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^3.9.5",
    "canvas": "^3.2.3",
    "glob": "^10.5.0",
    "gray-matter": "^4.0.3",
